rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isPresenceSessionFields(data) {
      return (!('activeSessionId' in data) || (data.activeSessionId is string && data.activeSessionId.size() <= 128))
        && (!('activeSessionAt' in data) || (data.activeSessionAt is string && data.activeSessionAt.size() <= 40));
    }

    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isStaffEmailAuth() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower().matches('.*@ez-hub\\.kr$');
    }

    function isMember(tenantId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getProfile().tenantId == tenantId
        && (
          request.auth.token.email_verified == true
          || isStaffEmailAuth()
          || getProfile().role in ['admin', 'staff']
        );
    }

    function isSuperAdmin() {
      return isSignedIn() &&
             request.auth.token.email == 'molnanle@gmail.com' &&
             request.auth.token.email_verified == true;
    }

    function isTenantOwnerOf(tenantId) {
      return isVerified()
        && exists(/databases/$(database)/documents/tenants/$(tenantId))
        && get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid;
    }

    function isAdmin(tenantId) {
      return isSuperAdmin()
        || isTenantOwnerOf(tenantId)
        || (isSignedIn()
            && exists(/databases/$(database)/documents/tenants/$(tenantId))
            && get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid)
        || (isMember(tenantId)
            && exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && getProfile().role == 'admin');
    }

    // --- Public / pre-auth helpers (staff login & signup, company search) ---
    function isReasonableListQuery() {
      return !('limit' in request.query) || request.query.limit <= 50;
    }

    function isTenantNameJoinCodeQuery() {
      return request.query.filters.size() == 2
        && request.query.filters[0].field.path == ['name']
        && request.query.filters[0].op == '=='
        && request.query.filters[1].field.path == ['joinCode']
        && request.query.filters[1].op == '==';
    }

    // 로그인/가입 화면 회사명 검색 (name == 쿼리)
    function isTenantNameSearchQuery() {
      return request.query.filters.size() == 1
        && request.query.filters[0].field.path == ['name']
        && request.query.filters[0].op == '=='
        && isReasonableListQuery();
    }

    // 회사명 부분 검색 (name >= … && name <= …\uf8ff)
    function isTenantNamePrefixSearchQuery() {
      return isReasonableListQuery()
        && request.query.filters.size() >= 2
        && request.query.filters.size() <= 3
        && request.query.filters[0].field.path == ['name']
        && request.query.filters[0].op == '>='
        && request.query.filters[1].field.path == ['name']
        && request.query.filters[1].op == '<=';
    }

    // tenants 목록 — 이름/입장코드 검색만 허용 (비필터 dump 금지)
    function isPublicTenantDiscovery() {
      return isTenantNameSearchQuery()
        || isTenantNamePrefixSearchQuery()
        || isTenantNameJoinCodeQuery();
    }

    // tenants/{id} 단건 — 멤버·슈퍼어드민만 (비로그인 get으로 joinCode 등 탈취 방지)
    function isPublicTenantDiscoveryGet() {
      return false;
    }

    // 직원 로그인: loginId == 조회만 허용 (비로그인 전체 list dump 금지)
    // ※ filters[0]만 보지 않고, limit 유무와 무관하게 loginId 등호 필터가 있으면 허용
    function hasLoginIdEqualityFilter() {
      return (request.query.filters.size() >= 1
          && request.query.filters[0].field.path == ['loginId']
          && request.query.filters[0].op == '==')
        || (request.query.filters.size() >= 2
          && request.query.filters[1].field.path == ['loginId']
          && request.query.filters[1].op == '==');
    }

    function isStaffLoginIdQuery() {
      return isReasonableListQuery()
        && request.query.filters.size() >= 1
        && request.query.filters.size() <= 3
        && hasLoginIdEqualityFilter();
    }

    /** 가입 좌석 추정 — active 필터 + limit (비로그인 전체 dump 금지) */
    function isStaffActiveSeatQuery() {
      return isReasonableListQuery()
        && request.query.filters.size() == 1
        && request.query.filters[0].field.path == ['active']
        && request.query.filters[0].op == '==';
    }

    function isStaffPreAuthRead() {
      return isStaffLoginIdQuery() || isStaffActiveSeatQuery();
    }

    function hasFilter(fieldName) {
      return request.query.filters.size() >= 1
        && (
          (request.query.filters[0].field.path == [fieldName] && request.query.filters[0].op == '==')
          || (request.query.filters.size() >= 2
            && request.query.filters[1].field.path == [fieldName] && request.query.filters[1].op == '==')
        );
    }

    function isStaffDuplicateCheckQuery() {
      return isReasonableListQuery()
        && request.query.filters.size() == 2
        && request.query.filters[0].op == '=='
        && request.query.filters[1].op == '=='
        && (
          (request.query.filters[0].field.path == ['tenantId'] && request.query.filters[1].field.path == ['loginId'])
          || (request.query.filters[0].field.path == ['loginId'] && request.query.filters[1].field.path == ['tenantId'])
        );
    }

    function isStaffSelfSignupUser(data) {
      return data.role == 'staff'
        && data.tenantId is string
        && isValidId(data.tenantId)
        && data.loginId is string
        && data.loginId.size() >= 4
        && data.loginId.size() <= 64
        && data.email is string
        && data.keys().hasAll(['email', 'tenantId', 'role', 'loginId']);
    }

    function isStaffSelfSignupStaff(data) {
      return data.name is string
        && data.name.size() >= 1
        && data.name.size() <= 50
        && data.loginId is string
        && data.loginId.size() >= 4
        && data.active == true
        && data.keys().hasAll(['name', 'loginId', 'active']);
    }

    function isStaffCredentialMigration(data) {
      return !isSignedIn()
        && resource != null
        && data.loginId is string
        && data.password is string
        && data.loginId == data.loginId.lower()
        && data.password == data.password.lower()
        && ('loginId' in resource.data)
        && resource.data.loginId is string
        && data.loginId.lower() == resource.data.loginId.lower()
        && (
          data.password.lower() == resource.data.password.lower()
          || data.password == resource.data.password
        );
    }

    function privilegeEscalation(data) {
      return ('tenantId' in data && 'tenantId' in existing() && data.tenantId != existing().tenantId)
        || ('role' in data && 'role' in existing() && data.role != existing().role);
    }

    function isAdminUpdatingMember(data) {
      return isSignedIn()
        && 'tenantId' in data
        && isValidId(data.tenantId)
        && isAdmin(data.tenantId)
        && (!('role' in data) || data.role in ['admin', 'staff'])
        && data.email is string
        && data.email.size() <= 256;
    }

    /** 관리자가 멤버 users 문서를 수정 (tenantId/role 누락·필드 수 등 유연 처리) */
    function isAdminMemberProfileUpdate() {
      return isSignedIn()
        && resource != null
        && (
          ('tenantId' in existing() && isValidId(existing().tenantId) && isAdmin(existing().tenantId))
          || ('tenantId' in incoming() && isValidId(incoming().tenantId) && isAdmin(incoming().tenantId))
        )
        && incoming().email is string
        && incoming().email.size() <= 256
        && (!('role' in incoming()) || incoming().role in ['admin', 'staff'])
        && (
          !('tenantId' in incoming())
          || !('tenantId' in existing())
          || incoming().tenantId == existing().tenantId
        );
    }

    /** 관리자가 직원 users/{uid} 프로필 생성·수정 (staff 등록 연동) */
    function isAdminWritingStaffUser() {
      return isSignedIn()
        && request.auth.uid != userId
        && incoming().email is string
        && incoming().email.size() <= 256
        && 'tenantId' in incoming()
        && isValidId(incoming().tenantId)
        && isAdmin(incoming().tenantId)
        && incoming().role in ['admin', 'staff'];
    }

    /** 관리자가 신규 직원 users/{uid} 프로필을 최초 생성할 때 */
    function isAdminProvisioningMember(data) {
      return isSignedIn()
        && request.auth.uid != userId
        && isAdminUpdatingMember(data);
    }

    // 2. User Profiles
    match /users/{userId} {
      // list·get — 중복체크 쿼리는 비로그인 list + 결과 문서 get 모두 필요
      allow read: if isSuperAdmin()
        || (isSignedIn() && request.auth.uid == userId)
        || isStaffDuplicateCheckQuery();
      allow create: if (isSignedIn() && request.auth.uid == userId && isValidUser(incoming()))
        || (!isSignedIn() && isStaffSelfSignupUser(incoming()))
        || (isSignedIn() && request.auth.uid == userId && isStaffLoginProfileUpsert(incoming()))
        || isAdminProvisioningMember(incoming())
        || isAdminWritingStaffUser();
      allow update: if isSuperAdmin()
        || (isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && !privilegeEscalation(incoming()))
        || (isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && isOwnerOnboardingUpdate(incoming()))
        || (isSignedIn() && request.auth.uid == userId && isStaffLoginProfileUpsert(incoming()))
        || (isSignedIn() && request.auth.uid == userId && isPresenceSelfUpdate(incoming()))
        || isAdminUpdatingMember(incoming())
        || isAdminMemberProfileUpdate()
        || isAdminWritingStaffUser();
      allow delete: if isSuperAdmin();

      /** EzPrintWork 로그인·heartbeat — presence 관련 필드만 변경 허용 */
      function isPresenceSelfUpdate(data) {
        return resource != null
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isOnline', 'lastActive', 'online', 'activeSessionId', 'activeSessionAt'])
          && data.isOnline is bool
          && data.lastActive is string
          && data.lastActive.size() <= 40
          && (!('online' in data) || data.online is bool)
          && isPresenceSessionFields(data);
      }

      function isOwnerOnboardingUpdate(data) {
        return data.role == 'admin'
          && data.tenantId is string
          && isValidId(data.tenantId)
          && (!('tenantId' in existing()) || existing().tenantId == null)
          && exists(/databases/$(database)/documents/tenants/$(data.tenantId))
          && get(/databases/$(database)/documents/tenants/$(data.tenantId)).data.ownerId == request.auth.uid;
      }

      function staffDocForLogin(tenantId, staffDocId) {
        return get(/databases/$(database)/documents/tenants/$(tenantId)/staff/$(staffDocId)).data;
      }

      /** 직원 로그인 — 실제 staff 문서와 loginId/권한 대조 필수 (임의 admin 부여 금지) */
      function isStaffLoginProfileUpsert(data) {
        return isSignedIn()
          && request.auth.uid == userId
          && data.role in ['admin', 'staff']
          && data.tenantId is string
          && isValidId(data.tenantId)
          && data.email is string
          && data.email.lower() == request.auth.token.email.lower()
          && data.loginId is string
          && data.loginId.size() >= 2
          && data.loginId.size() <= 64
          && data.staffDocId is string
          && isValidId(data.staffDocId)
          && exists(/databases/$(database)/documents/tenants/$(data.tenantId)/staff/$(data.staffDocId))
          && staffDocForLogin(data.tenantId, data.staffDocId).loginId is string
          && staffDocForLogin(data.tenantId, data.staffDocId).loginId.lower() == data.loginId.lower()
          && staffDocForLogin(data.tenantId, data.staffDocId).active != false
          && staffDocForLogin(data.tenantId, data.staffDocId).isDeleted != true
          && (
            !('uid' in staffDocForLogin(data.tenantId, data.staffDocId))
            || staffDocForLogin(data.tenantId, data.staffDocId).uid == null
            || staffDocForLogin(data.tenantId, data.staffDocId).uid == ''
            || staffDocForLogin(data.tenantId, data.staffDocId).uid == request.auth.uid
          )
          && (
            data.role == 'staff'
            || (data.role == 'admin' && staffDocForLogin(data.tenantId, data.staffDocId).isCompanyAdmin == true)
          );
      }

      function isValidUser(data) {
        return data.email is string && data.email.size() <= 256 &&
               (!('tenantId' in data) || data.tenantId == null || isValidId(data.tenantId)) &&
               (!('role' in data) || data.role in ['admin', 'staff', 'superadmin']) &&
               data.keys().hasAll(['email']) && data.keys().size() <= 40;
      }
    }

    // 3. Tenants
    match /tenants/{tenantId} {
      // 회사 검색: list 쿼리 허용 + get은 검색 결과 문서 읽기 (로그인 여부 무관)
      allow list: if isSuperAdmin() || isPublicTenantDiscovery();
      allow get: if isSuperAdmin() || isMember(tenantId) || isPublicTenantDiscoveryGet();
      allow create: if isVerified() && isValidTenant(incoming()) && incoming().ownerId == request.auth.uid;
      // 요금/결제/소유자 필드는 슈퍼어드민만 (카드결제 웹훅·Admin SDK 연동 전까지 클라이언트 조작 차단)
      allow update: if isValidTenant(incoming())
        && (
          isSuperAdmin()
          || (isAdmin(tenantId) && tenantBillingFieldsUnchanged())
        );
      allow delete: if isSuperAdmin();

      function isValidPlan(plan) {
        return plan in ['free', 'lite', 'pro', 'pro_plus', 'service']
          || plan.matches('^u[0-9]+$');
      }

      function tenantBillingFieldsUnchanged() {
        // ownerId는 Google UID 마이그레이션 등 기존 복구 경로를 위해 관리자 갱신 허용
        return !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['plan', 'paymentStatus', 'maxStaff', 'licenseExpiresAt']);
      }

      function isValidTenant(data) {
        return data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
               (!('plan' in data) || isValidPlan(data.plan)) &&
               data.keys().hasAll(['name', 'ownerId']);
      }

      function isTenantOwner(tenantId) {
        return isTenantOwnerOf(tenantId);
      }

      // JOBS
      match /jobs/{jobId} {
        allow list: if isMember(tenantId);
        allow get: if isMember(tenantId);
        allow create: if isMember(tenantId) && isValidId(jobId) && isValidJob(incoming());
        allow update: if isMember(tenantId) && isValidId(jobId) && isValidJob(incoming());
        allow delete: if isAdmin(tenantId);
      }

      function isValidJob(data) {
        return data.title is string && data.title.size() <= 200 &&
               data.status is string && data.status.size() <= 50 &&
               (!('assignedStaffIds' in data) || data.assignedStaffIds is list) &&
               data.keys().hasAll(['title', 'status']);
      }

      function isStaffUidSelfLink(data) {
        return isStaffEmailAuth()
          && resource != null
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid', 'active'])
          && 'uid' in data
          && data.uid == request.auth.uid
          && (!('active' in data) || data.active == true)
          && (
            !('uid' in resource.data)
            || resource.data.uid == null
            || resource.data.uid == ''
            || resource.data.uid == request.auth.uid
          );
      }

      /** EzPrintWork 로그인·heartbeat — presence 필드만 변경 허용 */
      function isStaffPresenceSelfUpdate(staffId, data) {
        return isStaffEmailAuth()
          && isValidId(staffId)
          && resource != null
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isOnline', 'lastActive', 'online', 'activeSessionId', 'activeSessionAt', 'uid'])
          && data.isOnline is bool
          && data.lastActive is string
          && data.lastActive.size() <= 40
          && isPresenceSessionFields(data)
          && (
            staffId == request.auth.uid
            || ('uid' in resource.data && resource.data.uid == request.auth.uid)
            || ('uid' in data && data.uid == request.auth.uid)
          );
      }

      // STAFF — 비로그인: loginId·active 쿼리만 (전체 list dump 금지)
      match /staff/{staffId} {
        allow read: if isSuperAdmin()
          || isMember(tenantId)
          || isStaffPreAuthRead()
          || isStaffEmailAuth();
        allow create: if (isAdmin(tenantId) && isValidId(staffId) && isValidStaff(incoming()))
          || (!isSignedIn() && isValidId(staffId) && isStaffSelfSignupStaff(incoming()))
          || (isTenantOwner(tenantId) && request.auth.uid == staffId && isValidId(staffId) && isValidStaff(incoming()));
        allow update: if (isAdmin(tenantId) && isValidId(staffId) && isValidStaff(incoming()))
          || (!isSignedIn() && isStaffCredentialMigration(incoming()))
          || (isStaffUidSelfLink(incoming()) && isValidId(staffId))
          || (isStaffPresenceSelfUpdate(staffId, incoming()) && isValidId(staffId));
        allow delete: if isAdmin(tenantId);
      }

      function isValidStaff(data) {
        return data.name is string && data.name.size() >= 1 && data.name.size() <= 50 &&
               (!('phone' in data) || data.phone is string) &&
               data.keys().hasAll(['name']);
      }

      // JOIN REQUESTS (Google user → company join flow)
      match /joinRequests/{requestId} {
        allow list, get: if isAdmin(tenantId);
        allow create: if isVerified()
          && isValidId(requestId)
          && isValidJoinRequest(incoming())
          && incoming().userId == request.auth.uid
          && incoming().status == 'pending';
        allow update: if isAdmin(tenantId) && isValidId(requestId);
        allow delete: if isAdmin(tenantId);
      }

      function isValidJoinRequest(data) {
        return data.userId is string
          && data.userEmail is string
          && data.userName is string
          && data.userName.size() <= 50
          && data.status in ['pending', 'approved', 'rejected']
          && data.keys().hasAll(['userId', 'userEmail', 'userName', 'status']);
      }

      // CLIENTS — 직원: 등록·수정(작업 연동), 관리자: 삭제·합치기
      match /clients/{clientId} {
        allow read: if isMember(tenantId);
        allow create: if isMember(tenantId) && isValidId(clientId) && isValidClient(incoming());
        allow update: if isMember(tenantId) && isValidId(clientId) && isValidClient(incoming());
        allow delete: if isAdmin(tenantId);
      }

      function isValidClient(data) {
        return data.name is string && data.name.size() <= 100 &&
               data.keys().hasAll(['name']);
      }

      // QUOTES — 직원: 작성·수정, 관리자: 삭제
      match /quotes/{quoteId} {
        allow read: if isMember(tenantId);
        allow create: if isMember(tenantId) && isValidId(quoteId) && isValidQuote(incoming());
        allow update: if isMember(tenantId) && isValidId(quoteId) && isValidQuote(incoming());
        allow delete: if isAdmin(tenantId);
      }

      function isValidQuote(data) {
        return data.clientName is string && data.clientName.size() <= 100 &&
               data.totalAmount is number &&
               data.keys().hasAll(['clientName', 'totalAmount']);
      }

      // INSTRUCTIONS — 관리자만 등록·수정·삭제
      match /instructions/{instId} {
        allow read: if isMember(tenantId);
        allow create: if isAdmin(tenantId) && isValidId(instId) && isValidInstruction(incoming());
        allow update: if isAdmin(tenantId) && isValidId(instId) && isValidInstruction(incoming());
        allow delete: if isAdmin(tenantId);
      }

      function isValidInstruction(data) {
        return data.content is string && data.content.size() <= 1000 &&
               data.keys().hasAll(['content']);
      }

      // MESSAGES
      match /messages/{msgId} {
        allow list: if isMember(tenantId);
        allow create: if isMember(tenantId) && isValidId(msgId) && isValidMessage(incoming());
      }

      function isValidMessage(data) {
        return data.content is string && data.content.size() <= 5000 &&
               data.senderId == request.auth.uid &&
               data.keys().hasAll(['content', 'senderId']);
      }

      // LEAVES — 본인 휴가 등록 + 관리자 전체 등록
      match /leaves/{leaveId} {
        allow read: if isMember(tenantId);
        allow create: if isMember(tenantId) && isValidId(leaveId) && isValidLeave(incoming())
          && (isAdmin(tenantId) || isOwnLeaveStaff(tenantId, incoming().staffId));
        allow update: if isMember(tenantId) && isValidId(leaveId) && isValidLeave(incoming())
          && (isAdmin(tenantId) || isOwnLeaveStaff(tenantId, incoming().staffId));
        allow delete: if isMember(tenantId) && isValidId(leaveId)
          && (isAdmin(tenantId) || isOwnLeaveStaff(tenantId, existing().staffId));
      }

      function staffData(tenantId, staffId) {
        return get(/databases/$(database)/documents/tenants/$(tenantId)/staff/$(staffId)).data;
      }

      function isOwnLeaveStaff(tenantId, staffId) {
        return exists(/databases/$(database)/documents/tenants/$(tenantId)/staff/$(staffId))
          && (
            ('uid' in staffData(tenantId, staffId) && staffData(tenantId, staffId).uid == request.auth.uid)
            || ('email' in staffData(tenantId, staffId) && staffData(tenantId, staffId).email.lower() == request.auth.token.email.lower())
            || staffId == request.auth.uid
          );
      }

      function isValidLeave(data) {
        return data.staffId is string
          && data.startDate is string
          && data.endDate is string
          && data.type in ['연차', '반차', '병가', '기타']
          && data.keys().hasAll(['staffId', 'startDate', 'endDate', 'type']);
      }

      // PAPERS
      match /papers/{paperId} {
        allow read: if isMember(tenantId);
        allow write: if isAdmin(tenantId) && isValidId(paperId) && isValidPaper(incoming());
      }

      function isValidPaper(data) {
        return data.name is string && data.name.size() <= 100 &&
               data.keys().hasAll(['name']);
      }

      // SETTINGS — 관리자/대표만 쓰기 (상품·후가공 마스터 포함)
      match /settings/{settingId} {
        allow read: if isMember(tenantId) || isSuperAdmin();
        allow write: if (isAdmin(tenantId) && isValidId(settingId))
          || (isTenantOwner(tenantId) && isValidId(settingId));
      }

      // SYNC PULSE — 테넌트 실시간 변경 신호 (문서 1개만 구독)
      match /sync/{pulseId} {
        allow read, write: if isMember(tenantId) && isValidId(pulseId);
      }

      // BACKUPS
      match /backups/{backupId} {
        allow read, write: if isAdmin(tenantId) && isValidId(backupId);
      }
    }

    // 5. Invitations
    match /invitations/{email} {
      allow get: if isSignedIn() && request.auth.token.email.lower() == email.lower();
      allow create, update: if isSignedIn() && isAdmin(incoming().tenantId);
      allow delete: if isSignedIn() && (request.auth.token.email.lower() == email.lower() || isAdmin(existing().tenantId));
    }
  }
}
