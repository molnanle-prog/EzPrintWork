{
  "name": "ezprintwork",
  "version": "1.6.6",
  "author": "EzPrintWork",
  "description": "인쇄소 통합 관리 시스템",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "build": "node scripts/build.js",
    "serve": "vite preview",
    "lint": "tsc --noEmit",
    "package": "electron-builder",
    "deploy": "node scripts/deploy.js",
    "deploy:app": "node scripts/deploy-app.js",
    "deploy:all": "node scripts/deploy-app.js",
    "test:smoke": "node scripts/verify_firestore_rules.mjs && npx -y tsx scripts/smoke_admin_access_ts.ts && npm run test:smoke:staff",
    "publish:release": "node scripts/publish-github-release.js",
    "release:all": "node scripts/release-and-sync.mjs",
    "sync:downloads": "node scripts/sync-github-latest-yml.mjs",
    "sync:downloads:github": "node scripts/github-download-meta.mjs latest",
    "setup:home": "node scripts/home-setup.mjs",
    "test:smoke:staff": "npx -y tsx scripts/smoke_staff_match.ts && npx -y tsx scripts/smoke_staff_seats.ts && npx -y tsx scripts/smoke_staff_login_recovery.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "better-sqlite3": "^12.6.2",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.3.0",
    "electron-updater": "^6.8.9",
    "firebase": "^12.13.0",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.562.0",
    "motion": "^12.38.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.13.1",
    "react-to-print": "^3.2.0",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "tesseract.js": "^5.0.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3",
    "firebase-admin": "^14.0.0",
    "firebase-tools": "^15.19.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  },
  "build": {
    "appId": "com.ezprintwork.app",
    "productName": "EzPrintWork",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "artifactName": "EzPrintWork-Setup.${ext}",
    "publish": [
      {
        "provider": "generic",
        "url": "https://ez-hub.kr/downloads/"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "EzPrintWork",
      "include": "build/installer.nsh"
    }
  }
}
